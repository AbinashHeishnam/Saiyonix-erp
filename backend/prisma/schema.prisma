generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleType {
  SUPER_ADMIN
  ADMIN
  ACADEMIC_SUB_ADMIN
  FINANCE_SUB_ADMIN
  TEACHER
  PARENT
  STUDENT
}

model Role {
  id        String   @id @default(uuid())
  type      RoleType @unique
  createdAt DateTime @default(now())

  users User[]
}

model User {
  id           String   @id @default(uuid())
  roleId       String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  role Role @relation(fields: [roleId], references: [id])
}
