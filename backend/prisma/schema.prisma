  REJECTED
  CANCELLED
}

enum LeaveType {
  SICK
  CASUAL
  EMERGENCY
  OTHER
}

enum CircularTargetType {
  ALL
  CLASS
  SECTION
  ROLE
}

enum NoticeTargetType {
  ALL
  CLASS
  SECTION
  ROLE
}

enum CertificateType {
