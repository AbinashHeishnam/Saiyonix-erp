  MORNING
  AFTERNOON
}

enum ExamMarksStatus {
  PENDING
  SUBMITTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  EXCUSED
}

enum AcademicCalendarEventType {
  SESSION_START
  SESSION_END
  HOLIDAY
  TEMPORARY_HOLIDAY
  HALF_DAY
  EXAM_START
  EXAM_END
  IMPORTANT_NOTICE
  OTHER
