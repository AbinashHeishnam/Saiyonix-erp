{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@saiyonix/types": ["packages/types/src"],
      "@saiyonix/types/*": ["packages/types/src/*"],
      "@saiyonix/utils": ["packages/utils/src"],
      "@saiyonix/utils/*": ["packages/utils/src/*"],
      "@saiyonix/api": ["packages/api/src"],
      "@saiyonix/api/*": ["packages/api/src/*"],
      "@saiyonix/auth": ["packages/auth/src"],
      "@saiyonix/auth/*": ["packages/auth/src/*"],
      "@saiyonix/ui": ["packages/ui/src"],
      "@saiyonix/ui/*": ["packages/ui/src/*"]
    },
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
